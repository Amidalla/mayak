<footer class="footer">
    <div class="footer-main">
        <div class="container">
            <div class="block">
                <div class="column">
                    <div class="wrap">
                        {{ logo(image="./assets/images/system/logo-variant.svg") }}
                    </div>
                    <div class="wrap">
                        {% include "components/common/contacts-footer/contacts-footer.njk" %}
                    </div>
                </div>
                <div class="wrap">
                    {{ navigationBottom(
                        title="Продукция",
                        items=[
                            { title: "Кабели радиочастотные", href: "./catalog-category.html" },
