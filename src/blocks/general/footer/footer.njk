{% from "components/general/logo/logo.njk" import render as logo %}
{% from "components/general/navigation-bottom/navigation-bottom.njk" import render as navigationBottom %}

<footer class="footer">
    <div class="footer-main">
        <div class="container">
            <div class="block">
                <!-- Колонка 1: Логотип + текст -->
                <div class="column">
                    <div class="wrap">
                        {{ logo(image="./assets/images/system/logo.svg") }}
                    </div>
                    <div class="wrap">
                        {% include "components/common/text-footer/text-footer.njk" %}
                    </div>
                    <div class="wrap">
                    {% include "components/common/contacts-footer/contacts-footer.njk" %}
                     <button class="footer-btn" data-src="popup-callback">
                           <span>Заказать звонок</span>
                     </button>
                    </div>
                </div>

                <!-- Колонка 2: О компании с подменю -->
                <div class="wrap">
                    {{ navigationBottom(
                        items=[
                            {
                                title: "О компании",
                                href: "./about.html",
                                children: [
                                    { title: "Фотогалерея", href: "./gallery.html" }
                                ]
                            }
                        ]
                    ) }}
                </div>

                <!-- Колонка 3: Каталог с подменю -->
                <div class="wrap">
                    {{ navigationBottom(
                        items=[
                            {
                                title: "Каталог",
                                href: "./catalog.html",
                                children: [
                                    { title: "Каталог (уровень 2)", href: "./catalog-level-2.html" },
                                    { title: "Каталог (уровень 2)", href: "./catalog-level-2.html" }
                                ]
                            }
                        ]
                    ) }}
                </div>

                <!-- Колонка 4: Партнеры, Статьи, Вопрос-ответ, Контакты -->
                <div class="wrap">
                    <button class="footer-btn" data-src="popup-callback">
                        <span>Заказать звонок</span>
                    </button>
                    {{ navigationBottom(
                        items=[
                            { title: "Партнеры", href: "./partners.html" },
                            { title: "Статьи", href: "./articles.html" },
                            { title: "Вопрос-ответ", href: "./faq.html" },
                            { title: "Контакты", href: "./contacts.html" }
                        ]
                    ) }}
                </div>
            </div>
        </div>
    </div>

    <div class="footer-bottom">
        <div class="container">
            <div class="block">
                <div class="wrap">
                    {% include "components/common/contacts-footer/contacts-footer.njk" %}
                </div>
                <div class="wrap">
                    {% include "components/common/footer-address/footer-address.njk" %}
                </div>
                <div class="wrap">
                    {% include "components/common/copyright/copyright.njk" %}
                </div>
            </div>
        </div>
    </div>
    <div class="footer-bg">
       <img class="lazy" src="./assets/images/content/footer-bg.svg" alt="">
    </div>
</footer>