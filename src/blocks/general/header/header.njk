{% from "components/general/navigation-top/navigation-top.njk" import render as navigationTop %}
{% from "components/general/logo/logo.njk" import render as logo %}

<header class="header">
    <div class="header-top">
        <div class="container">
            <div class="block">
                <div class="wrap">
                    {{ navigationTop(
                        items=[
                            { title: "Компания", href: "#", children: [{ title: "О компании", href: "./about.html" }, { title: "Реквизиты", href: "./requisites.html" }, { title: "Уставные документы", href: "./documents.html" }, { title: "Вакансии", href: "./vacancies.html" }] },
                            { title: "Оплата и доставка", href: "#", children: [{ title: "Оплата", href: "./payment.html" }, { title: "Доставка", href: "./delivery.html" }, { title: "Гарантия качества", href: "./warranty.html" }] },
                            { title: "Контакты", href: "./contacts.html" }
                        ]
                    ) }}
                </div>
                <div class="wrap">
                    {% include "components/common/contacts-header/contacts-header.njk" %}
                </div>
                <div class="wrap">
                    {% include "components/general/menu/menu-open.njk" %}
                </div>
            </div>
        </div>
    </div>
    <div class="header-main">
        <div class="container">
            <div class="block">
                <div class="wrap">{{ logo(image="./assets/images/system/logo.svg", imageMobile="./assets/images/system/logo-mini.svg") }}</div>
                <div class="wrap">
                    {% include "components/common/catalog-dropdown/catalog-dropdown.njk" %}
                </div>
                <div class="wrap">
                    {% include "components/general/search-form/search-form.njk" %}
                </div>
                <div class="wrap">
                    {% include "components/common/file-header/file-header.njk" %}
                </div>
                <div class="wrap">
                    {% include "components/common/mini-cart/mini-cart.njk" %}
                </div>
            </div>
        </div>
    </div>
</header>