{# blocks/common/faq-content/faq-content.njk #}

<section class="faq-content section bg">
    <div class="container">
        <div class="faq-content__grid">
            <!-- Левая колонка -->
            <div class="faq-content__column">
                {% from "components/general/accordion/accordion.njk" import render as accordion %}

                {{ accordion(
                    items=[
                        {
                            name: "Какой у вас график работы?",
                            content: "Мы работаем с понедельника по пятницу, 10:00-18:00. В выходные дни мы не работаем, но заявки, оставленные через форму на сайте, обрабатываются в первый рабочий день."
                        },
                        {
                            name: "Как оформить заказ?",
                            content: "Для оформления заказа вы можете связаться с нами по телефону, написать на email или оставить заявку через форму на сайте. Наши менеджеры свяжутся с вами для уточнения деталей."
                        },
                        {
                            name: "Какие способы оплаты вы принимаете?",
                            content: "Мы принимаем оплату по безналичному расчету, наличными при самовывозе, а также банковскими картами через наш сайт."
                        },
                        {
                            name: "Сколько времени занимает доставка?",
                            content: "Срок доставки зависит от вашего региона и способа доставки. Обычно доставка занимает от 1 до 5 рабочих дней. Точные сроки уточняйте у наших менеджеров."
                        }
                    ],
                    openFirst=true,
                    class="faq-content__accordion"
                ) }}
            </div>

            <!-- Правая колонка -->
            <div class="faq-content__column">
                {{ accordion(
                    items=[
                        {
                            name: "Есть ли у вас гарантия?",
                            content: "Да, на всю продукцию предоставляется гарантия от производителя. Срок гарантии зависит от конкретного изделия и указывается в документации."
                        },
                        {
                            name: "Можно ли вернуть товар?",
                            content: "Да, вы можете вернуть товар надлежащего качества в течение 14 дней с момента покупки. Возврат осуществляется в соответствии с законодательством."
                        },
                        {
                            name: "Предоставляете ли вы консультации?",
                            content: "Да, наши специалисты бесплатно консультируют клиентов по всем вопросам, связанным с выбором, эксплуатацией и обслуживанием продукции."
                        }
                    ],
                    openFirst=false,
                    class="faq-content__accordion"
                ) }}
            </div>
        </div>
    </div>
</section>