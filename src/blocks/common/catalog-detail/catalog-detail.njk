{% from "components/general/button/button.njk" import render as button %}
{% from "components/general/table/table.njk" import render as dataTable %}
{% from "components/common/product-navigation/product-navigation.njk" import render as productNavigation %}
{% from "components/common/product-properties/product-properties.njk" import render as productProperties %}
{% from "components/common/product-description/product-description.njk" import render as productDescription %}
{% from "components/common/product-delivery/product-delivery.njk" import render as productDelivery %}
{% from "components/common/product-payment/product-payment.njk" import render as productPayment %}
{% from "components/common/catalog-navigation/catalog-navigation.njk" import render as catalogNavigation %}
{% from "components/common/product-quantity/product-quantity.njk" import render as productQuantity %}

{% set navItems = [
    { title: "Описание", href: "#product-description" },
    { title: "Характеристики", href: "#product-properties" },
    { title: "Доставка", href: "#product-delivery" },
    { title: "Оплата", href: "#product-payment" }
] %}

<section class="catalog-detail section">
    <div class="container">
        <div class="block">
            <div class="top">{{ catalogNavigation(items=catalogNavItems) }}</div>
            <div class="grid">
                <div class="box">
                    <div class="column">
                        {% include "components/common/product-gallery/product-gallery.njk" %}
                    </div>
                    <div class="column">
                        {% include "components/common/product-title/product-title.njk" %}
                        {% include "components/common/product-sku/product-sku.njk" %}
                        {% include "components/common/product-price/product-price.njk" %}
                        {% include "components/common/product-stock/product-stock.njk" %}
                        <div class="row">
                            {{ productQuantity() }}
                            <button class="button primary md" type="button" data-quantity-submit disabled>
                                <svg
                                    width="25"
                                    height="25"
                                    viewBox="0 0 25 25"
                                    fill="none"
                                    xmlns="http://www.w3.org/2000/svg"
                                >
                                    <path
                                        d="M5.27246 6.00684C5.30587 6.00585 5.35583 6.00922 5.4082 6.03418C5.43578 6.04732 5.45932 6.06446 5.47949 6.08398L5.53027 6.14941C5.57447 6.2264 5.58789 6.32362 5.58887 6.39648C5.5894 6.4361 5.58531 6.48925 5.57129 6.54395L7.31152 10.8398H18.2842L19.9561 6.77637C19.9258 6.67894 19.9311 6.57283 19.9775 6.47852L20.0381 6.3877C20.109 6.30773 20.2095 6.25761 20.3174 6.24902H20.3652C20.4766 6.25752 20.5773 6.32866 20.6309 6.43066C20.6934 6.54993 20.6864 6.69393 20.6279 6.84082L20.6289 6.8418L19.2109 10.8398H21.8145C21.9355 10.8414 22.0508 10.8945 22.1289 10.9873V10.9883C22.1875 11.0584 22.2207 11.1454 22.2236 11.2354L22.2158 11.3262L20.499 20.1055C20.4611 20.2992 20.2908 20.435 20.0977 20.4375H13.4414V20.4365C13.3334 20.4373 13.2283 20.3975 13.1494 20.3223L13.1484 20.3213C13.0693 20.245 13.0235 20.1397 13.0234 20.0283C13.0234 19.9169 13.0698 19.8107 13.1494 19.7344C13.2279 19.6595 13.3327 19.6182 13.4414 19.6191H19.7559L21.3145 11.6572H4.28125L5.83984 19.6191H12.1533C12.2621 19.6181 12.3677 19.6591 12.4463 19.7344C12.5262 19.8108 12.5723 19.9169 12.5723 20.0283C12.5722 20.1396 12.5257 20.2449 12.4463 20.3213C12.3673 20.397 12.2616 20.4374 12.1533 20.4365V20.4375H5.49805C5.30501 20.435 5.13372 20.2995 5.0957 20.1055L3.37891 11.3271L3.37109 11.2412C3.37239 11.1557 3.4015 11.0723 3.4541 11.0029C3.52368 10.9111 3.62815 10.8527 3.74219 10.8408L3.75391 10.8398H6.38281L4.87109 6.61426L4.87207 6.61328C4.80944 6.46367 4.81035 6.32013 4.87695 6.20312C4.93775 6.09656 5.04796 6.0265 5.15918 6.02148V6.02051C5.16723 6.02012 5.17708 6.01865 5.19629 6.01562C5.21098 6.01331 5.24151 6.00776 5.27246 6.00684ZM8.11328 12.9229C8.20163 12.9307 8.28596 12.9672 8.35352 13.0273H8.35449C8.44279 13.1064 8.49173 13.2198 8.48926 13.3389H8.49023V17.9346C8.4919 18.0459 8.44731 18.152 8.36914 18.2295V18.2305C8.29103 18.3075 8.18464 18.3496 8.0752 18.3496C7.96586 18.3495 7.86017 18.3071 7.78223 18.2305V18.2295C7.70405 18.152 7.65948 18.0459 7.66113 17.9346V13.3389