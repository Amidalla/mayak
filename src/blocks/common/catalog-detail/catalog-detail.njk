                                        fill="white"
                                        stroke="white"
                                        stroke-width="0.4"
                                    />
                                    <path
                                        d="M12.7977 2.97656V7.73847M12.7977 7.73847L15.4763 5.14704M12.7977 7.73847L10.1191 5.14704"
                                        stroke="white"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    />
                                </svg>
                                <span>Добавить в заказ</span>
                            </button>
                        </div>
                    </div>
                    <div class="column">
                        {{ productNavigation(items=navItems) }} {{ productDescription(id="product-description") }}
                        {% set propertiesItems = [
                            { name: "Влажность воздуха при 25°С [%]", value: "98" },
                            { name: "Импульсное напряжение [В]", value: "700" },
                            { name: "Испытательное переменное напряжение частотой 50 Гц, 5 мин. [кВ]", value: "1.5" },
                            { name: "Максимальная рабочая температура жилы [°С]", value: "+220" },
                            { name: "Рабочее переменное напряжение частотой 5 кГц [В]", value: "250" },
                            { name: "Рабочее постоянное напряжение [В]", value: "350" },
                            { name: "Строительная длина, не менее [м]", value: "15" }
                        ] %}
                        {% call productProperties(title="Характеристики", id="product-properties") %}
                            {% call dataTable(class="properties") %}
                                <table>
                                    <tbody>
                                        {% for item in propertiesItems %}
                                            <tr>
                                                <td>{{ item.name }}</td>
                                                <td>{{ item.value }}</td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            {% endcall %}
                            {% call dataTable(class="center") %}
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Кол-во и сечение жил, шт. х кв. мм</th>
                                            <th>Число и диаметр проволок в жиле, шт х мм</th>
                                            <th>Масса кабеля, кг/км</th>
                                            <th>Наружный диаметр не более, мм</th>
                                            <th>Сопротивление проводника при 20°C, не более Ом/км</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>1х0,03</td>
                                            <td>7х0,08</td>
                                            <td>0,63</td>
                                            <td>0,56</td>
                                            <td>569,45</td>
                                        </tr>
                                        <tr>
                                            <td>1</td>
                                            <td>2</td>
                                            <td>3</td>
                                            <td>3</td>
                                            <td>3</td>
                                        </tr>
                                    </tbody>
                                </table>
                            {% endcall %}
                        {% endcall %}
                        {{ productDelivery(id="product-delivery") }} {{ productPayment(id="product-payment") }}
                    </div>
                </div>
                <aside>
                    <div class="inner">
                        {% include "components/common/widget-product-delivery/widget-product-delivery.njk" %}
                        {% include "components/common/widget-product-calculate/widget-product-calculate.njk" %}
                    </div>
                </aside>
            </div>
        </div>
    </div>
</section>