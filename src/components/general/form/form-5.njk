{% from "components/general/button/button.njk" import render as button %}
{% from "components/general/select/select.njk" import render as select %}
{% from "components/general/input/input.njk" import render as input %}
{% from "components/general/textarea/textarea.njk" import render as textarea %}
{% from "components/general/consent-checkbox/consent-checkbox.njk" import render as consentCheckbox %}
{% from "components/general/input-file/input-file.njk" import render as inputFile %}

<form class="form" data-validate>
    <div class="grid">
        <div class="field">
            <label class="label" for="popup-feedback-name">Ваше имя</label>
            {{ input(
                type="text",
                id="popup-feedback-name",
                name="name",
                placeholder="Ваше имя*",
                autocomplete="name",
                required=true,
                minlength="2",
                data={"error": "Введите имя (минимум 2 буквы)"}
            ) }}
        </div>
        <div class="field">
            <label class="label" for="popup-feedback-email">E-mail</label>
            {{ input(
                type="email",
                id="popup-feedback-email",
                name="email",
                placeholder="E-mail*",
                autocomplete="email",
                data={"error": "Неверный формат"},
                required=true
            ) }}
        </div>
        <div class="field">
            <label class="label" for="popup-feedback-phone">Ваш телефон</label>
            {{ input(
                type="tel",
                id="popup-feedback-phone",
                name="phone",
                placeholder="Ваш телефон*",
                autocomplete="tel",
                data={"mask": "phone", "error": "Введите полный номер телефона"},
                required=true
            ) }}
        </div>
        <div class="field">
            <label class="label" for="popup-feedback-message">Сообщение</label>
            {{ textarea(
                id="popup-feedback-message",
                name="message",
                rows="3",
                placeholder="Сообщение"
            ) }}
        </div>
        <div class="field-file">
            {{ inputFile(
                id="popup-feedback-file",
                accept=".pdf,.jpg,.jpeg,.png",
                maxSize=1024,
                errorSize="Максимальный размер файла 1MB",
                errorType="Допустимы только PDF, JPG, PNG",
                placeholder="Прикрепить файл",
                hint="(не более 1MB, pdf, jpg)"
            ) }}
        </div>
        <div class="field-consent">
            {{ consentCheckbox(
                id="popup-feedback-consent",
                data={"error": "Необходимо отметить"},
                required=true
            ) }}
        </div>
        <div class="actions">
            {{ button(
                text="Отправить",
                type="submit",
                disabled=true
            ) }}
        </div>
    </div>
</form>