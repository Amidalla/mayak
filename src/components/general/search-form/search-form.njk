                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
            />
        </svg>
    </button>
    <div class="search-dropdown">
        <!-- Поле поиска -->
        <div class="search-header">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="23" viewBox="0 0 22 23" fill="none">
                <path
                    d="M9.43432 18.6583C11.1541 18.66 12.8358 18.1367 14.2672 17.1544C15.6985 16.1721 16.8153 14.7748 17.4765 13.1391C18.1373 11.5031 18.3116 9.70182 17.9773 7.96364C17.643 6.22545 16.8151 4.62876 15.5986 3.37611C14.3829 2.12296 12.834 1.26926 11.1475 0.922894C9.46101 0.576531 7.71272 0.753055 6.12359 1.43016C4.53445 2.10726 3.1758 3.25454 2.21935 4.72701C1.26289 6.19948 0.75157 7.93104 0.75 9.70284C0.75 12.0765 1.66459 14.3521 3.2927 16.0307C4.92133 17.7094 7.12953 18.6543 9.43324 18.6583M15.6019 16.0552L20.75 21.3561"
