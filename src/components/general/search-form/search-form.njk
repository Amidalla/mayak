                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                />
            </svg>
            <input type="text" placeholder="Поиск..." />
        </div>

        <!-- Результаты поиска -->
        <div class="search-results">
            <div class="search-category">
                <h4 class="search-category__title">Товары</h4>
                <div class="search-category__items">
                    {{ catalogCard({
                        image: "./assets/images/content/search-img2.jpg",
                        name: "Эл.двигатель 5АИ 112 М4",
                        description: "GU 5.5 / 1500 об.мин / IM 1081",
                        inStock: true,
                        link: "./product.html"
                    }) }}

                    {{ catalogCard({
                        image: "./assets/images/content/search-img2.jpg",
                        name: "Эл.двигатель 5АИ 112 М4",
                        description: "GU 5.5 / 1500 об.мин / IM 1081",
                        inStock: false,
                        link: "./product.html"
                    }) }}

                    {{ catalogCard({
                        image: "./assets/images/content/search-img2.jpg",
                        name: "Эл.двигатель 5АИ 112 М4",
                        description: "GU 5.5 / 1500 об.мин / IM 1081",
                        inStock: true,
                        link: "./product.html"
                    }) }}

                    {{ catalogCard({
                        image: "./assets/images/content/search-img3.png",
                        name: "Эл.двигатель 5АИ 112 М4",
                        description: "GU 5.5 / 1500 об.мин / IM 1081",
                        inStock: false,
                        link: "./product.html"
                    }) }}
