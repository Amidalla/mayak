{% macro render(
        items=[],
        class="",
        ariaLabel="Навигация"
    ) %}
    {% set navClasses = "navigation-bottom" %}
    {% if class %}
        {% set navClasses = navClasses + " " + class %}
    {% endif %}

    <nav class="{{ navClasses }}" aria-label="{{ ariaLabel }}">
        <ul>
            {% for item in items %}
                <li {% if item.class %}class="{{ item.class }}" {% endif %}>
                    <a
                        href="{{ item.href }}"
                        {% if item.title %}
                            title="{{ item.title }}"
                        {% endif %}
                        {% if item.target %}
                            target="{{ item.target }}"
                        {% endif %}
                        {% if item.ariaCurrent %}
                            aria-current="{{ item.ariaCurrent }}"
                        {% endif %}
                    >
                        {{ item.title }}
                    </a>
                    {% if item.children %}
                        <ul class="navigation-bottom__submenu">
                            {% for child in item.children %}
                                <li>
                                    <a
                                        href="{{ child.href }}"
                                        {% if child.title %}
                                            title="{{ child.title }}"
                                        {% endif %}
                                        {% if child.target %}
                                            target="{{ child.target }}"
                                        {% endif %}
                                    >
                                        {{ child.title }}
                                    </a>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    </nav>
{% endmacro %}