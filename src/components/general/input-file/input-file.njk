{% macro render(
        id="",
        name="file",
        required=false,
        placeholder="Прикрепить файл",
        hint="",
        accept="",
        maxSize=200,
        errorSize="Файл слишком большой",
        errorType="Недопустимый формат файла",
        class="",
        data={},
        aria={}
    ) %}
    {% set inputClasses = "input-file" %}
    {% if class %}
        {% set inputClasses = inputClasses + " " + class %}
    {% endif %}

    <div
        class="{{ inputClasses }}"
        {% if data %}
            {% for key, val in data %}
                data-{{ key | replace("_", "-") }}="{{ val }}"
            {% endfor %}
        {% endif %}
    >
        <input
            type="file"
            {% if id %}id="{{ id }}"{% endif %}
            {% if name %}name="{{ name }}"{% endif %}
            {% if required %}required{% endif %}
            {% if accept %}accept="{{ accept }}"{% endif %}
            data-max-size="{{ maxSize }}"
            data-error-size="{{ errorSize }}"
            data-error-type="{{ errorType }}"
            {% if aria %}
                {% for key, val in aria %}
                    aria-{{ key | replace("_", "-") }}="{{ val }}"
                {% endfor %}
            {% endif %}
        />
        <label {% if id %}for="{{ id }}" {% endif %}>
            <span class="icon">
                <svg width="33" height="33" viewBox="0 0 33 33" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path
                        d="M22.9621 18.4484C22.4099 19.0655 21.6307 19.4225 20.819 19.4225H8.25193V20.7213H20.8512C22.0527 20.7213 23.1891 20.2017 23.9686 19.2925L24.131 19.0976C25.5273 17.5064 25.4624 15.1036 24.0011 13.5774C23.2219 12.7656 22.1176 12.2785 20.9812 12.2785L8.51206 12.2788C6.88842 12.2788 5.32969 12.9605 4.22567 14.1623C2.18006 16.4028 2.18006 19.8775 4.25815 22.0855L4.3231 22.1504C5.42712 23.3192 6.98579 23.9687 8.57701 23.9687H22.9623C25.1054 23.9687 27.1512 23.0271 28.58 21.4034L28.6125 21.3385C31.0479 18.5783 31.0479 14.3569 28.645 11.597C27.2159 9.97359 25.1703 9.03174 22.9948 9.03174H8.25241V10.3306H22.9948C24.7808 10.3306 26.4692 11.1098 27.6382 12.4737C29.6188 14.7792 29.6188 18.2538 27.6057 20.5271L27.5732 20.592C26.4042 21.9234 24.7156 22.7026 22.9298 22.7026L8.5774 22.7029C7.34344 22.7029 6.14204 22.1832 5.26534 21.2741L5.20039 21.2091C3.57675 19.488 3.57675 16.7928 5.16791 15.0395C6.01212 14.1304 7.24601 13.5782 8.47996 13.5782H20.9491C21.7283 13.5782 22.4753 13.903 22.9947 14.4549C24.0012 15.5264 24.0337 17.1501 23.0921 18.2541L22.9621 18.4484Z"
                        fill="#322F2F"
                    />
                </svg>
            </span>
            <span class="text" data-placeholder="{{ placeholder }}" data-hint="{{ hint }}"
                >{{ placeholder }}{% if hint %}
                <small>{{ hint }}</small>
            {% endif %}</span>
    </label>
    <span class="error"></span>
</div>
{% endmacro %}