{% macro render(items = [], id = "", class = "") %}
    {% set componentClasses = "files" %}
    {% if class %}
        {% set componentClasses = componentClasses + " " + class %}
    {% endif %}

    <div
        class="{{ componentClasses }}"
        {% if id %}
            id="{{ id }}"
        {% endif %}
    >
        {% if title %}
            <div class="title">{{ title }}</div>
        {% endif %}
        {% if items.length %}
            {% for item in items %}
                <a href="{{ item.href }}" class="item" target="_blank" rel="noopener noreferrer" download>
                    <span class="icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
