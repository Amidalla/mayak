                                d="M18.117 3.20213C19.6064 3.20213 20.7979 4.41489 20.7979 5.88298V18.117C20.7979 19.6064 19.5851 20.7979 18.117 20.7979H5.88298C4.39362 20.7979 3.20213 19.5851 3.20213 18.117V5.88298C3.20213 4.39362 4.41489 3.20213 5.88298 3.20213H18.117ZM18.117 1.5H5.88298C3.45745 1.5 1.5 3.45745 1.5 5.88298V18.117C1.5 20.5426 3.45745 22.5 5.88298 22.5H18.117C20.5426 22.5 22.5 20.5426 22.5 18.117V5.88298C22.5 3.45745 20.5426 1.5 18.117 1.5Z"
