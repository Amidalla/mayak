{% macro render(
        items=[],
        class="",
        ariaLabel="Навигация"
    ) %}
    {% set navClasses = "navigation-top" %}
    {% if class %}
        {% set navClasses = navClasses + " " + class %}
    {% endif %}

    <nav class="{{ navClasses }}" aria-label="{{ ariaLabel }}">
        <ul>
            {% for item in items %}
                {% set hasChildren = item.children and item.children | length > 0 %}
                <li class="{{ 'has-children ' if hasChildren else '' }}{{ item.class if item.class else '' }}">
                    <a
                        href="{{ item.href }}"
                        {% if item.target %}
                            target="{{ item.target }}"
                        {% endif %}
                        {% if item.ariaCurrent %}
                            aria-current="{{ item.ariaCurrent }}"
                        {% endif %}
                    >
                        {{ item.title }}
                    </a>
                    {% if hasChildren %}
                        <ul class="submenu">
                            {% for child in item.children %}
                                <li>
                                    <a
                                        href="{{ child.href }}"
                                        {% if child.target %}
                                            target="{{ child.target }}"
                                        {% endif %}
                                    >
                                        {{ child.title }}
                                        <svg xmlns="http://www.w3.org/2000/svg" width="12" height="21" viewBox="0 0 12 21" fill="none">
                                            <path d="M0.707123 0.707092L10.3768 10.377L0.707123 20.0467" stroke-width="2" />
                                        </svg>
                                    </a>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    </nav>
{% endmacro %}