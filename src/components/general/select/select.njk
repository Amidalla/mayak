{% macro render(
        size="md",
        id="",
        name="",
        placeholder="",
        disabled=false,
        required=false,
        error=false,
        class="",
        data={},
        aria={},
        options=[]
    ) %}
    {% set selectClasses = "select " + size %}
    {% if error %}
        {% set selectClasses = selectClasses + " error" %}
    {% endif %}
    {% if class %}
        {% set selectClasses = selectClasses + " " + class %}
    {% endif %}

    <div
        class="{{ selectClasses }}"
        {% if placeholder %}data-placeholder="{{ placeholder }}"{% endif %}
    >
        <select
            {% if id %}id="{{ id }}"{% endif %}
            {% if name %}name="{{ name }}"{% endif %}
            {% if disabled %}disabled{% endif %}
            {% if required %}required{% endif %}
            {% if data %}
                {% for key, val in data %}
                    data-{{ key | replace("_", "-") }}="{{ val }}"
                {% endfor %}
            {% endif %}
            {% if aria %}
                {% for key, val in aria %}
                    aria-{{ key | replace("_", "-") }}="{{ val }}"
                {% endfor %}
            {% endif %}
        >
            {% if placeholder %}
                <option value="" disabled selected>{{ placeholder }}</option>
            {% endif %}
            {% for option in options %}
                <option
                    value="{{ option.value }}"
                    {% if option.selected %}selected{% endif %}
                    {% if option.disabled %}disabled{% endif %}
                >
                    {{ option.text }}
                </option>
            {% endfor %}
        </select>
    </div>
{% endmacro %}