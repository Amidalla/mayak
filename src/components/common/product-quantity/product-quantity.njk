{% macro render(
        value="",
        min=0,
        max=99999999,
        name="quantity",
        class="",
        disabled=false
    ) %}
    {% set quantityClasses = "product-quantity " + class %}
    {% if disabled %}
        {% set quantityClasses = quantityClasses + " disabled" %}
    {% endif %}

    <div class="{{ quantityClasses }}" data-quantity>
        <button
            type="button"
            class="minus"
            aria-label="Уменьшить количество"
            data-quantity-minus{% if disabled %}
            disabled{% endif %}
    >
        <svg
            aria-hidden="true"
            width="18"
            height="18"
            viewBox="0 0 18 18"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
        >
            <path d="M4.5 9H13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
    </button>
    <input
        type="number"
        name="{{ name }}"
        value="{{ value }}"
        min="{{ min }}"
        max="{{ max }}"
        placeholder="0"
        inputmode="numeric"
        data-quantity-input{% if disabled %}
        disabled{% endif %}
    />
    <button
        type="button"
        class="plus"
        aria-label="Увеличить количество"
        data-quantity-plus{% if disabled %}
        disabled{% endif %}
    >
        <svg
            aria-hidden="true"
            width="18"
            height="18"
            viewBox="0 0 18 18"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
        >
            <path d="M4.5 9H13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
            <path d="M9 4.5V13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
    </button>
</div>
{% endmacro %}