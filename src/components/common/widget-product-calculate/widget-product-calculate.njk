    <div class="box">
        <div class="title">Масса и наружный диаметр</div>
        <div class="row">
            <div class="field">
                <label class="label" for="product-calculate">Выберите сечение</label>
                {{ select(
                    id="product-calculate",
                    name="product-diameter",
                    placeholder="Выбрать сечение",
                    options=[
                        { value: "1", text: "1" },
                        { value: "2", text: "2" },
                        { value: "3", text: "3" }
                    ]
                ) }}
            </div>
            <div class="field">
                <label class="label" for="product-long">Метраж</label>
                {{ input(
                    type="number",
                    id="product-long",
                    name="product-long",
                    placeholder="Метраж"
                ) }}
            </div>
        </div>
    </div>
    <div class="results">
        <div class="item">
            <div class="title">Расчетная масса</div>
            <div class="value"><span>497,0</span> кг</div>
        </div>
        <div class="item">
            <div class="title">Наружный диаметр</div>
            <div class="value"><span>12,5</span> мм</div>
        </div>
    </div>
